    <select id="selectHomeworkSubmissionList" parameterType="HomeworkSubmission" resultMap="HomeworkSubmissionResult">
        <choose>
            <when test="params.studentView != null and params.studentView">
                select
                t.task_id,
                t.task_title as taskTitle,
                t.deadline_time as deadlineTime,
                u.nick_name as teacherName,
                c.course_name as subject,

                s.submission_id,
                s.student_id,
                s.status,
                s.score,
                s.create_time,
                s.submit_time
                from homework_task t
                left join homework_submission s on t.task_id = s.task_id and s.student_id = #{studentId}
                left join sys_user u on t.teacher_id = u.user_id
                left join sys_course c on t.course_id = c.course_id
                <where>
                    <!-- 🔥 按班级过滤 (解决"按班级划分"需求) -->
                    <if test="params.classId != null">
                        AND t.class_id = #{params.classId}
                    </if>

                    <if test="params.onlyUnexpired != null">
                        AND t.deadline_time > NOW()
                    </if>
                    <if test="status != null and status != ''">
                        AND (s.status = #{status} OR s.status IS NULL)
                    </if>
                    
                    <!-- 新增：科目筛选 -->
                    <if test="params.subject != null and params.subject != ''">
                        AND t.task_title like concat('%', #{params.subject}, '%')
                    </if>
                    
                    <!-- 新增：状态筛选 (submitted, unsubmitted, expired) -->
                    <if test="params.filterStatus == 'submitted'">
                        AND s.submission_id IS NOT NULL
                    </if>
                    <if test="params.filterStatus == 'unsubmitted'">
                        AND s.submission_id IS NULL AND t.deadline_time > NOW()
                    </if>
                    <if test="params.filterStatus == 'expired'">
                        AND s.submission_id IS NULL AND t.deadline_time &lt;= NOW()
                    </if>
                </where>
                order by 
                (CASE WHEN s.submission_id IS NULL AND t.deadline_time &lt;= NOW() THEN 1 ELSE 0 END) ASC,
                t.deadline_time ASC
            </when>

            <otherwise>
                select
                s.submission_id, s.task_id, s.student_id, s.student_name, s.submit_content, s.submit_files, s.submit_time, s.status, s.score, s.teacher_comment, s.grade_time, s.grader_id, s.create_by, s.create_time, s.update_by, s.update_time, s.remark,
                t.task_title as taskTitle,
                t.deadline_time as deadlineTime,
                teacher.nick_name as teacherName,
                c.course_name as subject
                from homework_submission s
                left join homework_task t on s.task_id = t.task_id
                left join sys_user u on s.student_id = u.user_id
                left join sys_user teacher on t.create_by = teacher.user_name
                left join sys_course c on t.course_id = c.course_id
                <where>
                    <if test="taskId != null "> and s.task_id = #{taskId}</if>
                    <if test="studentId != null "> and s.student_id = #{studentId}</if>
                    <if test="studentName != null  and studentName != ''"> and s.student_name like concat('%', #{studentName}, '%')</if>
                    <if test="status != null  and status != ''"> and s.status = #{status}</if>
                    
                    <!-- 新增：科目筛选 (匹配作业标题) -->
                    <if test="params.subject != null and params.subject != ''">
                        AND t.task_title like concat('%', #{params.subject}, '%')
                    </if>

                    <!-- 新增：班级筛选 -->
                    <if test="params.deptId != null">
                        AND u.dept_id = #{params.deptId}
                    </if>
                </where>
                order by s.create_time desc
            </otherwise>
        </choose>
    </select>

    <select id="selectHomeworkSubmissionBySubmissionId" parameterType="Long" resultMap="HomeworkSubmissionResult">

        <include refid="selectHomeworkSubmissionVo"/>

        where submission_id = #{submissionId}

    </select>


