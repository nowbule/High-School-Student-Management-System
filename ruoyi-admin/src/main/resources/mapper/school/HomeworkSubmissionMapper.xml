            <if test="createBy != null">#{createBy},</if>

            <if test="createTime != null">#{createTime},</if>

            <if test="updateBy != null">#{updateBy},</if>

            <if test="updateTime != null">#{updateTime},</if>

            <if test="remark != null">#{remark},</if>

        </trim>

    </insert>



    <update id="updateHomeworkSubmission" parameterType="HomeworkSubmission">

        update homework_submission

        <trim prefix="SET" suffixOverrides=",">

            <if test="taskId != null">task_id = #{taskId},</if>

            <if test="studentId != null">student_id = #{studentId},</if>

            <if test="studentName != null">student_name = #{studentName},</if>

            <if test="submitContent != null">submit_content = #{submitContent},</if>

            <if test="submitFiles != null">submit_files = #{submitFiles},</if>

            <if test="submitTime != null">submit_time = #{submitTime},</if>

            <if test="status != null">status = #{status},</if>

            <if test="score != null">score = #{score},</if>

            <if test="teacherComment != null">teacher_comment = #{teacherComment},</if>

            <if test="gradeTime != null">grade_time = #{gradeTime},</if>

            <if test="graderId != null">grader_id = #{graderId},</if>

            <if test="createBy != null">create_by = #{createBy},</if>

            <if test="createTime != null">create_time = #{createTime},</if>

            <if test="updateBy != null">update_by = #{updateBy},</if>

            <if test="updateTime != null">update_time = #{updateTime},</if>

            <if test="remark != null">remark = #{remark},</if>

        </trim>

        where submission_id = #{submissionId}

    </update>


    <delete id="deleteHomeworkSubmissionBySubmissionId" parameterType="Long">

        delete from homework_submission where submission_id = #{submissionId}

    </delete>


    <delete id="deleteHomeworkSubmissionBySubmissionIds" parameterType="String">

        delete from homework_submission where submission_id in

        <foreach item="submissionId" collection="array" open="(" separator="," close=")">

            #{submissionId}

        </foreach>

    </delete>

    <select id="selectStudentScoreAnalysis" parameterType="HomeworkSubmission" resultMap="HomeworkSubmissionResult">
        select
            s.submission_id,
            s.student_id,
            s.score,
            s.grade_time,
            s.submit_time,
            t.task_title as taskTitle,
            COALESCE(c.course_name, 
                CASE 
                    WHEN t.task_title LIKE '%语文%' THEN '语文'
                    WHEN t.task_title LIKE '%数学%' THEN '数学'
                    WHEN t.task_title LIKE '%英语%' THEN '英语'
                    WHEN t.task_title LIKE '%物理%' THEN '物理'
                    WHEN t.task_title LIKE '%化学%' THEN '化学'
                    WHEN t.task_title LIKE '%生物%' THEN '生物'
                    WHEN t.task_title LIKE '%历史%' THEN '历史'
                    WHEN t.task_title LIKE '%地理%' THEN '地理'
                    WHEN t.task_title LIKE '%政治%' THEN '政治'
                    ELSE '综合'
                END
            ) as subject
        from homework_submission s
                 left join homework_task t on s.task_id = t.task_id
                 left join sys_course c on t.course_id = c.course_id
        where s.student_id = #{studentId}
          and s.status = '2'
        order by s.grade_time asc
    </select>

